{
  "cli": {
    "version": ">= 12.0.0",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "channel": "development",
      "ios": {
        "simulator": true
      },
      "env": {
        "APS_ENVIRONMENT": "development",
        "EXPO_PUBLIC_SENTRY_ENVIRONMENT": "development"
      }
    },
    "preview": {
      "distribution": "internal",
      "channel": "preview",
      "autoIncrement": true,
      "ios": {
        "simulator": false
      },
      "env": {
        "APS_ENVIRONMENT": "production",
        "EXPO_PUBLIC_SENTRY_ENVIRONMENT": "preview"
      }
    },
    "production": {
      "channel": "production",
      "autoIncrement": true,
      "env": {
        "APS_ENVIRONMENT": "production",
        "EXPO_PUBLIC_SENTRY_ENVIRONMENT": "production",
        "SENTRY_ORG": "PLACEHOLDER-sentry-org",
        "SENTRY_PROJECT": "lootlyfe"
      }
    }
  },
  "submit": {
    "preview": {
      "ios": {
        "appleId": "PLACEHOLDER@example.com",
        "ascAppId": "PLACEHOLDER_ASC_APP_ID",
        "appleTeamId": "PLACEHOLDER_TEAM_ID"
      }
    },
    "production": {
      "ios": {
        "appleId": "PLACEHOLDER@example.com",
        "ascAppId": "PLACEHOLDER_ASC_APP_ID",
        "appleTeamId": "PLACEHOLDER_TEAM_ID"
      },
      "android": {
        "serviceAccountKeyPath": "./google-service-account.json",
        "track": "internal"
      }
    }
  }
}
