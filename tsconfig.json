{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "strict": true,
    // Tests run on Node's native type stripping (node --test), which requires
    // explicit .ts extensions on relative imports. Safe under noEmit.
    "allowImportingTsExtensions": true,
    "baseUrl": ".",
    "paths": {
      "@/*": [
        "./src/*"
      ],
      "@app/*": [
        "./app/*"
      ]
    }
  },
  "include": [
    "**/*.ts",
    "**/*.tsx",
    ".expo/types/**/*.ts",
    "expo-env.d.ts",
    "nativewind-env.d.ts"
  ],
  "exclude": [
    "node_modules",
    "supabase/functions"
  ]
}