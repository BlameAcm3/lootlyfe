EXPO_PUBLIC_SUPABASE_URL=https://dlwjmrvljtxocpphyceu.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_JlxSLn7f-iDV6mNCgWhmVg_rBaA8nyy
EXPO_PUBLIC_POSTHOG_API_KEY=phc_u3t5S7ziYukwEbAuEjmWQbKSpeWhYhyvHqVRmy3JCDsC
EXPO_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# Adventurer (kid) mode analytics stays fully disabled unless explicitly "true"
# (Apple Kids Category compliance). Leave false.
EXPO_PUBLIC_ADVENTURER_ANALYTICS_ENABLED=false

# RevenueCat public SDK keys (per platform). Safe in the client — they only
# permit purchases; entitlement is written server-side by the revenuecat-webhook
# Edge Function. Leave blank in Expo Go (the SDK no-ops without a dev build).
EXPO_PUBLIC_REVENUECAT_IOS_KEY=
EXPO_PUBLIC_REVENUECAT_ANDROID_KEY=

# Premium gating master switch. Default behaviour is ON. Set to "false" to
# unlock every premium feature locally without a purchase (QA / TestFlight
# before sandbox products exist). Any value other than "false" keeps gating on.
EXPO_PUBLIC_PAYWALL_ENABLED=true

# Legal pages opened from NPC settings (COPPA). Placeholders for now.
EXPO_PUBLIC_PRIVACY_URL=https://lootlyfe.app/privacy
EXPO_PUBLIC_TERMS_URL=https://lootlyfe.app/terms

# Optional. Overrides EAS project id in app.config.ts (defaults to the linked expo.dev project).
# EXPO_PUBLIC_EAS_PROJECT_ID=

# Sentry crash/error reporting. DSN is public-safe (client-side). Empty = Sentry
# disabled (lib/sentry.ts no-ops). User context is stripped on adventurer sessions.
EXPO_PUBLIC_SENTRY_DSN=
# Optional. Defaults to development in dev builds, production otherwise. EAS
# profiles set this per build (see eas.json).
# EXPO_PUBLIC_SENTRY_ENVIRONMENT=

# Build-time only (NOT EXPO_PUBLIC) — consumed by the Sentry Expo plugin to
# upload source maps during EAS Build. SENTRY_ORG/PROJECT live in eas.json;
# SENTRY_AUTH_TOKEN must be an EAS secret (never commit it). See BUILD.md.
# SENTRY_ORG=
# SENTRY_PROJECT=lootlyfe
# SENTRY_AUTH_TOKEN=   (set via: eas secret:create --name SENTRY_AUTH_TOKEN)

# iOS APNs entitlement environment. Set per EAS profile (development|production).
# APS_ENVIRONMENT=production
